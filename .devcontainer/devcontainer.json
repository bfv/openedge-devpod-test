{
    "name": "OpenEdge DevPod Test",
    "dockerComposeFile": "docker-compose.yaml",
    "service": "devcontainer",
    "workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}",
    "features": {
    },
    // Configure tool-specific properties.
    "customizations": {
        // Configure properties specific to VS Code.
        "vscode": {
            "settings": {
                "abl.configuration.runtimes.default": "12.8",
                "abl.configuration.runtimes": [
                    {
                        "name": "12.8",
                        "path": "/usr/dlc"
                    }
                ],
                "abl.langServerJavaExecutable": "/opt/java/openjdk/bin/java",
                "abl.buildMode": 1,
            },
            "extensions": [
                "riversidesoftware.openedge-abl-lsp@prerelease",
            ]
        }
    },
    "mounts": [
        "source=${localEnv:USERPROFILE}/.gitconfig,target=/home/openedge/.gitconfig,type=bind,consistency=cached",
        "source=${localEnv:USERPROFILE}/.ssh/id_ed25519_sk.pub,target=/home/openedge/.ssh/id_ed25519_sk.pub,type=bind,consistency=cached",
    ],
    "containerEnv": {
        "PROPATH": "./src,./bin"
    },
    "forwardPorts": [
        // no debugger for now 
        // 3099
    ],
    // Use 'postCreateCommand' to run commands after the container is created.
    "initializeCommand": "",
    "postCreateCommand": "",
    "shutdownAction": "none"
}
